# ── Supabase (frontend) ────────────────────────────────────────────────────────
# Anon key is safe to expose in the frontend build.
# Get both values from: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ────────────────────────────────────────────────────────────────
# Local dev: http://localhost:8000
# Production: set to your Render service URL after deploying eduveda-python/
#   e.g. https://eduveda-api.onrender.com
VITE_API_URL=http://localhost:8000

# ── AI (optional — used by the direct Gemini path in demo mode) ───────────────
# Gemini key for frontend AI features when no backend AI config is set.
# Leave blank to use backend-only AI (recommended for production).
GEMINI_API_KEY=
