__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
*.egg-info/
.pytest_cache/

# ─── Java (eduveda-java/) ─────────────────────────────────────────────────────
target/
*.class
.mvn/

# ─── Local tooling ────────────────────────────────────────────────────────────
.claude/

